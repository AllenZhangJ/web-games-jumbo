{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "noEmit": true,
    "strict": false,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "packages/**/test/**/*.ts",
    "vitest.config.ts"
  ]
}
