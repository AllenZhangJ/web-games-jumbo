{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "exactOptionalPropertyTypes": false,
    "noEmit": true,
    "noImplicitAny": false,
    "noImplicitOverride": false,
    "noUncheckedIndexedAccess": false,
    "strict": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["src/**/*.js"]
}
