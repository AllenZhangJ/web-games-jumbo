{
  "name": "number-strategy-jump",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "基于确定性 MatchCore 与 Three.js/WebGL 的 1v1 Arena 动作小游戏，支持 Web、抖音和微信。",
  "scripts": {
    "prepare": "npm run build:packages",
    "build:packages": "tsc -b packages/arena-contracts packages/arena-evidence-contracts packages/arena-device-acceptance packages/arena-performance-evidence packages/arena-storage packages/arena-definitions packages/arena-core packages/arena-equipment packages/arena-map packages/arena-movement packages/arena-physics packages/arena-match packages/arena-experiment packages/arena-v1-content packages/arena-bot packages/arena-matchmaking packages/arena-session packages/arena-quick-match packages/arena-product-state packages/arena-progression packages/arena-product-contracts packages/arena-human-match-study packages/arena-input-pilot packages/arena-product-match packages/arena-profile-contracts packages/arena-profile-persistence packages/arena-profile-service packages/arena-product-progression packages/arena-product-content packages/arena-product-v1-content packages/arena-product-composition packages/arena-v1-composition packages/arena-balance packages/arena-v1-experiment packages/arena-regression packages/arena-product-session packages/arena-presentation-contracts packages/arena-presentation-runtime packages/arena-stage9-evidence-content packages/arena-human-match-study-verification packages/arena-product-presentation packages/arena-v1-presentation-content packages/arena-v1-application-session packages/arena-presentation-three packages/arena-product-presentation-three packages/arena-platform-contracts packages/arena-platform-runtime packages/arena-v1-application-launch packages/arena-v1-greybox-session packages/arena-input-pilot-presentation --pretty false",
    "postbuild:packages": "tsc -b packages/arena-release-contracts packages/arena-release --pretty false",
    "arena:poc": "node --import tsx scripts/arena-physics-poc.ts",
    "arena:config:print": "node --import tsx scripts/arena-gameplay-config.ts",
    "arena:poc:build": "node --import tsx scripts/build-arena-poc.ts",
    "arena:poc:stress": "node --import tsx scripts/arena-physics-poc.ts --stress-ticks=100000",
    "arena:stress": "node --expose-gc --import tsx scripts/arena-match-stress.ts --matches=1000",
    "arena:map:stress": "node --import tsx scripts/arena-map-stress.ts --matches=100",
    "arena:movement:stress": "node --import tsx scripts/arena-movement-stress.ts --matches=100",
    "arena:bot:stress": "node --import tsx scripts/arena-bot-stress.ts --matches=300",
    "arena:input:fuzz": "node --import tsx scripts/arena-input-fuzz.ts --matches=40",
    "arena:replay:verify": "node --import tsx scripts/arena-golden-replay.ts --verify",
    "arena:replay:candidate": "node --import tsx scripts/arena-golden-replay.ts",
    "arena:replay:promote": "node --import tsx scripts/arena-golden-replay.ts",
    "arena:regression:lifecycle": "node --import tsx --test tests/arena/local-match-session.test.ts tests/arena/replay.test.ts tests/arena/input/pointer-input-adapter.test.ts tests/arena/product/stage8-product-session.test.ts tests/arena/product/stage8-profile-persistence.test.ts tests/arena/presentation/product-presentation-session.test.ts",
    "arena:regression": "npm run arena:replay:verify && npm run arena:input:fuzz && npm run arena:regression:lifecycle && npm run arena:session:soak && npm run arena:product:session:soak",
    "arena:regression:evidence": "node --import tsx scripts/arena-regression-evidence.ts",
    "arena:session:soak": "node --expose-gc --import tsx scripts/arena-presentation-session-soak.ts --matches=100",
    "arena:product:session:soak": "node --expose-gc --import tsx scripts/arena-product-presentation-session-soak.ts --matches=100",
    "arena:profile:stress": "node --import tsx scripts/arena-profile-persistence-stress.ts --commits=500",
    "arena:product:stress": "node --import tsx scripts/arena-product-session-stress.ts --matches=200",
    "arena:experiment": "node --import tsx scripts/arena-experiment.ts",
    "arena:experiment:matchcore": "node --import tsx scripts/arena-experiment.ts --suite=matchcore-invariants --cases=1000 --replay-samples=5 --summary",
    "arena:experiment:map": "node --import tsx scripts/arena-experiment.ts --suite=map-timeline --cases=100 --replay-samples=3 --summary",
    "arena:experiment:movement": "node --import tsx scripts/arena-experiment.ts --suite=movement-stress --cases=100 --replay-samples=3 --summary",
    "arena:experiment:bot": "node --import tsx scripts/arena-experiment.ts --suite=bot-capability --cases=300 --replay-samples=3 --summary",
    "arena:experiment:balance": "node --import tsx scripts/arena-experiment.ts --suite=balance-candidate --summary",
    "arena:experiment:balance:explore": "node --import tsx scripts/arena-balance-exploration.ts",
    "arena:experiment:balance:validate": "node --import tsx scripts/arena-experiment.ts --suite=balance-validation --summary",
    "arena:experiment:balance:validate:describe": "node --import tsx scripts/arena-experiment.ts --suite=balance-validation --describe",
    "arena:experiment:report:verify": "node --import tsx scripts/arena-experiment-report.ts",
    "arena:device:evidence": "node --import tsx scripts/arena-device-evidence.ts",
    "arena:product:device:evidence": "node --import tsx scripts/arena-device-evidence.ts --definition arena.stage8.product-device-acceptance.v1",
    "arena:performance:evidence": "node --import tsx scripts/arena-device-evidence.ts --definition arena.stage9.performance-device-acceptance.v1",
    "arena:human-fairness:evidence": "node --import tsx scripts/arena-human-fairness-evidence.ts",
    "arena:human-fairness:ingest": "node --import tsx scripts/arena-human-fairness-ingest.ts",
    "arena:build:verify": "node --import tsx scripts/arena-build-manifest.ts",
    "arena:build:budget": "node --import tsx scripts/arena-build-budget.ts",
    "arena:stage9:readiness": "node --import tsx scripts/arena-stage9-readiness.ts",
    "arena:defects:verify": "node --import tsx scripts/arena-defects.ts",
    "arena:input-pilot:evidence": "node --import tsx scripts/arena-input-pilot-evidence.ts",
    "arena:assets:intake:verify": "node --import tsx scripts/arena-formal-asset-intake.ts",
    "arena:assets:budget": "node --import tsx scripts/arena-formal-asset-budget.ts",
    "arena:assets:optimize-characters": "node --import tsx scripts/arena-optimize-character-assets.ts",
    "dev": "vite --host 127.0.0.1",
    "dev:lan": "vite --host 0.0.0.0",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173 --strictPort --outDir dist/web",
    "lint": "eslint packages src scripts tests *.config.ts --max-warnings 0 --no-error-on-unmatched-pattern",
    "typecheck": "npm run build:packages && tsc -p tsconfig.app.json --pretty false",
    "test:node": "node --import tsx --test",
    "test:governance": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test": "npm run test:node && npm run test:governance",
    "check:js-migration": "node --import tsx scripts/governance/check-js-migration.ts",
    "check:product-boundaries": "node --import tsx scripts/governance/check-product-boundaries.ts",
    "check:presentation-three-boundaries": "node --import tsx scripts/governance/check-presentation-three-boundaries.ts",
    "check:production-artifacts": "node --import tsx scripts/governance/check-production-artifacts.ts",
    "check:supply-chain": "node --import tsx scripts/governance/check-supply-chain.ts",
    "check:repository-security": "node --import tsx scripts/governance/check-repository-security.ts",
    "check:third-party-assets": "node --import tsx scripts/governance/check-third-party-assets.ts",
    "check:formal-assets": "node --import tsx scripts/governance/check-formal-assets.ts",
    "check:documentation": "node --import tsx scripts/governance/check-documentation.ts",
    "check:governance": "npm run check:js-migration && npm run check:product-boundaries && npm run check:presentation-three-boundaries && npm run check:supply-chain && npm run check:repository-security && npm run check:third-party-assets && npm run check:formal-assets && npm run check:documentation && npm run lint && npm run typecheck && npm run test:coverage",
    "audit:dependencies": "npm audit --omit=dev --audit-level=high",
    "prebuild": "npm run build:packages",
    "build": "node --import tsx scripts/build.ts",
    "check": "npm run check:governance && npm run test:node && npm run arena:regression && npm run arena:assets:budget && npm run audit:dependencies && npm run build && npm run arena:build:verify -- --require-clean-source && npm run arena:build:budget && npm run check:production-artifacts"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/three": "0.185.1",
    "@vitest/coverage-v8": "3.2.7",
    "@gltf-transform/core": "4.4.1",
    "@gltf-transform/functions": "4.4.1",
    "esbuild": "0.25.12",
    "eslint": "9.39.5",
    "jiti": "2.7.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@number-strategy-jump/arena-balance": "0.1.0",
    "@number-strategy-jump/arena-bot": "0.1.0",
    "@number-strategy-jump/arena-contracts": "0.1.0",
    "@number-strategy-jump/arena-experiment": "0.1.0",
    "@number-strategy-jump/arena-regression": "0.1.0",
    "@number-strategy-jump/arena-human-match-study": "0.1.0",
    "@number-strategy-jump/arena-human-match-study-verification": "0.1.0",
    "@number-strategy-jump/arena-input-pilot": "0.1.0",
    "@number-strategy-jump/arena-input-pilot-presentation": "0.1.0",
    "@number-strategy-jump/arena-device-acceptance": "0.1.0",
    "@number-strategy-jump/arena-evidence-contracts": "0.1.0",
    "@number-strategy-jump/arena-performance-evidence": "0.1.0",
    "@number-strategy-jump/arena-stage9-evidence-content": "0.1.0",
    "@number-strategy-jump/arena-core": "0.1.0",
    "@number-strategy-jump/arena-definitions": "0.1.0",
    "@number-strategy-jump/arena-equipment": "0.1.0",
    "@number-strategy-jump/arena-map": "0.1.0",
    "@number-strategy-jump/arena-match": "0.1.0",
    "@number-strategy-jump/arena-matchmaking": "0.1.0",
    "@number-strategy-jump/arena-movement": "0.1.0",
    "@number-strategy-jump/arena-physics": "0.1.0",
    "@number-strategy-jump/arena-presentation-contracts": "0.1.0",
    "@number-strategy-jump/arena-presentation-runtime": "0.1.0",
    "@number-strategy-jump/arena-presentation-three": "0.1.0",
    "@number-strategy-jump/arena-product-contracts": "0.1.0",
    "@number-strategy-jump/arena-product-composition": "0.1.0",
    "@number-strategy-jump/arena-product-content": "0.1.0",
    "@number-strategy-jump/arena-product-match": "0.1.0",
    "@number-strategy-jump/arena-product-presentation": "0.1.0",
    "@number-strategy-jump/arena-product-presentation-three": "0.1.0",
    "@number-strategy-jump/arena-product-progression": "0.1.0",
    "@number-strategy-jump/arena-product-session": "0.1.0",
    "@number-strategy-jump/arena-product-state": "0.1.0",
    "@number-strategy-jump/arena-product-v1-content": "0.1.0",
    "@number-strategy-jump/arena-progression": "0.1.0",
    "@number-strategy-jump/arena-quick-match": "0.1.0",
    "@number-strategy-jump/arena-release-contracts": "0.1.0",
    "@number-strategy-jump/arena-release": "0.1.0",
    "@number-strategy-jump/arena-session": "0.1.0",
    "@number-strategy-jump/arena-storage": "0.1.0",
    "@number-strategy-jump/arena-v1-content": "0.1.0",
    "@number-strategy-jump/arena-v1-composition": "0.1.0",
    "@number-strategy-jump/arena-v1-experiment": "0.1.0",
    "@number-strategy-jump/arena-v1-application-session": "0.1.0",
    "@number-strategy-jump/arena-v1-application-launch": "0.1.0",
    "@number-strategy-jump/arena-v1-greybox-session": "0.1.0",
    "@number-strategy-jump/arena-v1-presentation-content": "0.1.0",
    "@number-strategy-jump/arena-profile-contracts": "0.1.0",
    "@number-strategy-jump/arena-profile-persistence": "0.1.0",
    "@number-strategy-jump/arena-profile-service": "0.1.0",
    "@number-strategy-jump/arena-platform-contracts": "0.1.0",
    "@number-strategy-jump/arena-platform-runtime": "0.1.0",
    "three": "0.185.1"
  }
}
