{
  "name": "number-strategy-jump",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "基于确定性 MatchCore 与 Three.js/WebGL 的 1v1 Arena 动作小游戏，支持 Web、抖音和微信。",
  "scripts": {
    "prepare": "npm run build:packages",
    "build:packages": "tsc -b packages/arena-contracts packages/arena-definitions packages/arena-core packages/arena-movement packages/arena-profile-contracts packages/arena-platform-contracts --pretty false",
    "arena:poc": "node scripts/arena-physics-poc.mjs",
    "arena:config:print": "node --import tsx scripts/arena-gameplay-config.ts",
    "arena:poc:build": "node scripts/build-arena-poc.mjs",
    "arena:poc:stress": "node scripts/arena-physics-poc.mjs --stress-ticks=100000",
    "arena:stress": "node --expose-gc scripts/arena-match-stress.mjs --matches=1000",
    "arena:map:stress": "node scripts/arena-map-stress.mjs --matches=100",
    "arena:movement:stress": "node scripts/arena-movement-stress.mjs --matches=100",
    "arena:bot:stress": "node scripts/arena-bot-stress.mjs --matches=300",
    "arena:input:fuzz": "node scripts/arena-input-fuzz.mjs --matches=40",
    "arena:replay:verify": "node scripts/arena-golden-replay.mjs --verify",
    "arena:replay:candidate": "node scripts/arena-golden-replay.mjs",
    "arena:replay:promote": "node scripts/arena-golden-replay.mjs",
    "arena:regression:lifecycle": "node --test tests/arena/local-match-session.test.js tests/arena/replay.test.js tests/arena/input/pointer-input-adapter.test.js tests/arena/product/stage8-product-session.test.js tests/arena/product/stage8-profile-persistence.test.js tests/arena/presentation/product-presentation-session.test.js",
    "arena:regression": "npm run arena:replay:verify && npm run arena:input:fuzz && npm run arena:regression:lifecycle && npm run arena:session:soak && npm run arena:product:session:soak",
    "arena:regression:evidence": "node scripts/arena-regression-evidence.mjs",
    "arena:session:soak": "node --expose-gc scripts/arena-presentation-session-soak.mjs --matches=100",
    "arena:product:session:soak": "node --expose-gc scripts/arena-product-presentation-session-soak.mjs --matches=100",
    "arena:profile:stress": "node scripts/arena-profile-persistence-stress.mjs --commits=500",
    "arena:product:stress": "node scripts/arena-product-session-stress.mjs --matches=200",
    "arena:experiment": "node scripts/arena-experiment.mjs",
    "arena:experiment:matchcore": "node scripts/arena-experiment.mjs --suite=matchcore-invariants --cases=1000 --replay-samples=5 --summary",
    "arena:experiment:map": "node scripts/arena-experiment.mjs --suite=map-timeline --cases=100 --replay-samples=3 --summary",
    "arena:experiment:movement": "node scripts/arena-experiment.mjs --suite=movement-stress --cases=100 --replay-samples=3 --summary",
    "arena:experiment:bot": "node scripts/arena-experiment.mjs --suite=bot-capability --cases=300 --replay-samples=3 --summary",
    "arena:experiment:balance": "node scripts/arena-experiment.mjs --suite=balance-candidate --summary",
    "arena:experiment:balance:explore": "node scripts/arena-balance-exploration.mjs",
    "arena:experiment:balance:validate": "node scripts/arena-experiment.mjs --suite=balance-validation --summary",
    "arena:experiment:balance:validate:describe": "node scripts/arena-experiment.mjs --suite=balance-validation --describe",
    "arena:experiment:report:verify": "node scripts/arena-experiment-report.mjs",
    "arena:device:evidence": "node scripts/arena-device-evidence.mjs",
    "arena:product:device:evidence": "node scripts/arena-device-evidence.mjs --definition arena.stage8.product-device-acceptance.v1",
    "arena:performance:evidence": "node scripts/arena-device-evidence.mjs --definition arena.stage9.performance-device-acceptance.v1",
    "arena:human-fairness:evidence": "node scripts/arena-human-fairness-evidence.mjs",
    "arena:human-fairness:ingest": "node scripts/arena-human-fairness-ingest.mjs",
    "arena:build:verify": "node scripts/arena-build-manifest.mjs",
    "arena:build:budget": "node scripts/arena-build-budget.mjs",
    "arena:stage9:readiness": "node scripts/arena-stage9-readiness.mjs",
    "arena:defects:verify": "node scripts/arena-defects.mjs",
    "arena:input-pilot:evidence": "node scripts/arena-input-pilot-evidence.mjs",
    "arena:assets:intake:verify": "node scripts/arena-formal-asset-intake.mjs",
    "arena:assets:budget": "node scripts/arena-formal-asset-budget.mjs",
    "arena:assets:optimize-characters": "node scripts/arena-optimize-character-assets.mjs",
    "dev": "vite --host 127.0.0.1",
    "dev:lan": "vite --host 0.0.0.0",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173 --strictPort --outDir dist/web",
    "lint": "eslint packages src scripts tests *.config.ts --max-warnings 0 --no-error-on-unmatched-pattern",
    "typecheck": "npm run build:packages && tsc -p tsconfig.app.json --pretty false",
    "test:node": "node --test",
    "test:governance": "vitest run",
    "test": "npm run test:node && npm run test:governance",
    "check:js-migration": "node --import tsx scripts/governance/check-js-migration.ts",
    "check:product-boundaries": "node --import tsx scripts/governance/check-product-boundaries.ts",
    "check:production-artifacts": "node --import tsx scripts/governance/check-production-artifacts.ts",
    "check:governance": "npm run check:js-migration && npm run check:product-boundaries && npm run lint && npm run typecheck && npm run test:governance",
    "audit:dependencies": "npm audit --omit=dev --audit-level=high",
    "prebuild": "npm run build:packages",
    "build": "node scripts/build.mjs",
    "check": "npm run check:governance && npm run test:node && npm run arena:regression && npm run arena:assets:budget && npm run audit:dependencies && npm run build && npm run arena:build:verify -- --require-clean-source && npm run arena:build:budget && npm run check:production-artifacts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/three": "^0.185.1",
    "@vitest/coverage-v8": "^3.2.7",
    "@gltf-transform/core": "4.4.1",
    "@gltf-transform/functions": "4.4.1",
    "esbuild": "^0.25.6",
    "eslint": "^9.30.0",
    "jiti": "^2.4.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@number-strategy-jump/arena-contracts": "0.1.0",
    "@number-strategy-jump/arena-core": "0.1.0",
    "@number-strategy-jump/arena-definitions": "0.1.0",
    "@number-strategy-jump/arena-movement": "0.1.0",
    "@number-strategy-jump/arena-profile-contracts": "0.1.0",
    "@number-strategy-jump/arena-platform-contracts": "0.1.0",
    "three": "0.185.1"
  }
}
